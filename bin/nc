#!/usr/bin/env python3
"""
nc — Nextcloud WebDAV CLI v3.1.0 (agent-optimized)

WHAT THIS IS
  A command-line client for a Nextcloud server's WebDAV/OCS API, built to be
  driven by autonomous agents. Every command:
    - returns a SEMANTIC EXIT CODE (below) so you can branch without parsing text
    - accepts --json for machine output: {"ok",bool,"http_code",str,"data",..,"error",str|null}
    - prints concise human output by default

CONFIG (read from env, or ~/.hermes/.env)
  NEXTCLOUD_URL           e.g. https://cloud.example.com
  NEXTCLOUD_USER          login name
  NEXTCLOUD_APP_PASSWORD  app password (Settings > Security > App passwords)

EXIT CODES — branch on these, they are the contract
  0  success
  2  not found (404)         path is wrong; do NOT retry
  3  auth failure (401/403)  fix credentials; do NOT retry
  4  conflict (409/412)      target exists; use --overwrite / drop --no-clobber / new name
  5  server error (5xx)      transient; safe to retry (auto-retried once)
  6  network/curl error      transient; safe to retry (auto-retried once)
  7  usage error             fix your arguments
  8  size limit (413)        server cap hit; lower --chunk-size or raise server limit
  9  checksum mismatch (400) source changed mid-upload; re-read and retry

COMMANDS
  ls       [path] [--json] [--recursive]            List a directory
  upload   <local> <remote> [opts]                  Upload a file (auto-chunks large files)
  download <remote> <local>                         Download a file (verifies size)
  mkdir    <path>                                   Create a directory (idempotent)
  mv       <src> <dst> [--overwrite]                Move / rename
  cp       <src> <dst> [--overwrite]                Copy
  rm       <path>                                   Delete a file or directory
  search   <query> [path] [--json]                  Find by filename (server SEARCH)
  info     <path> [--json]                          File/dir metadata
  quota    [path] [--json]                          Storage used / available
  share    <path> [--pw PASS|--password-env VAR|--password-stdin] Create a public share link
  version                                           Show version
  help                                              Show this guide

  upload options:
    --no-chunk         force a single PUT instead of chunked upload
    --chunk-size MB    chunk size in MB (default 100; files larger than this chunk)
    --no-clobber       refuse to overwrite an existing target (exit 4)

  global flags:
    --json             machine-readable output (where supported)
    --no-retry         disable the automatic single retry on 5xx/network errors

UPLOAD BEHAVIOR (why large files used to 502)
  - Files larger than the chunk size (default 100 MB) use Nextcloud's chunked
    upload API automatically. Each chunk is a small PUT, so reverse proxies no
    longer time out on one huge request. Force one request with --no-chunk.
  - Integrity is verified server-side with OC-Checksum (SHA1); a mismatch -> exit 9.
  - The source file's mtime is preserved (X-OC-MTime).
  - Overwrites by default; pass --no-clobber to refuse if the target exists.
  - Missing parent dirs are auto-created when the server supports it
    (Nextcloud 32+, header X-NC-WebDAV-AutoMkcol).
  - Timeouts scale with file size; progress shows only on an interactive TTY,
    so cron logs stay clean.

AGENT TIPS
  - Read .ok and .http_code from --json instead of scraping human text.
  - Check space before a big upload:   nc quota --json
  - If `search` returns exit 5 ("not supported"), fall back to:
      nc ls <path> --json --recursive | jq '[.data.items[]|select(.name|test("Q"))]'
  - mkdir is idempotent (existing dir -> ok). rm of a missing path -> exit 2.
  - On exit 5 or 6, retrying is safe (operations here are idempotent).

EXAMPLES
  nc ls /HERMES-DROP/ --json
  nc upload ./backup.zip /HERMES-DROP/backup.zip
  nc upload ./big.zip /HERMES-DROP/big.zip --chunk-size 50
  nc download /HERMES-DROP/file.pdf ./file.pdf
  nc quota
  nc info /HERMES-DROP/file.pdf --json
  nc share /HERMES-DROP/report.pdf --pw s3cret
"""

import hashlib
import html
import os
import sys
import subprocess
import tempfile
import time
import urllib.parse
import uuid
import json
import re
from pathlib import Path

VERSION = "3.1.0"
HTTP_CODE_MARKER = "NC_HTTP_CODE:"

# ── Env loading ──────────────────────────────────────────────────────────────

def _load_env():
    env_path = Path.home() / ".hermes" / ".env"
    if not env_path.exists():
        return
    for line in env_path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, val = line.split("=", 1)
        key, val = key.strip(), val.strip().strip("\"'")
        if key and key not in os.environ:
            os.environ[key] = val

_load_env()

URL = os.environ.get("NEXTCLOUD_URL", "").rstrip("/")
USER = os.environ.get("NEXTCLOUD_USER", "")
TOKEN = os.environ.get("NEXTCLOUD_APP_PASSWORD", "")

if not all([URL, USER, TOKEN]):
    sys.stderr.write("ERROR: Missing NEXTCLOUD_URL, NEXTCLOUD_USER, or NEXTCLOUD_APP_PASSWORD\n")
    sys.exit(7)

DAV_BASE = f"{URL}/remote.php/dav/files/{USER}"
DAV_PREFIX = f"/remote.php/dav/files/{USER}"  # for stripping hrefs

# Exit code constants
EXIT_OK = 0
EXIT_NOT_FOUND = 2
EXIT_AUTH = 3
EXIT_CONFLICT = 4
EXIT_SERVER = 5
EXIT_NETWORK = 6
EXIT_USAGE = 7
EXIT_SIZE_LIMIT = 8
EXIT_CHECKSUM = 9

# Number of automatic retries on transient failures (5xx / network).
# Set to 0 by the global --no-retry flag.
RETRIES = 1

# Files larger than this (MB) are uploaded via Nextcloud's chunked upload API.
DEFAULT_CHUNK_MB = 100

def http_exit_code(code: str) -> int:
    """Map HTTP status to semantic exit code."""
    if code == "404":
        return EXIT_NOT_FOUND
    if code in ("401", "403"):
        return EXIT_AUTH
    if code in ("409", "412"):
        return EXIT_CONFLICT
    if code == "413":
        return EXIT_SIZE_LIMIT
    if code.startswith("5"):
        return EXIT_SERVER
    return EXIT_SERVER  # catch-all for unexpected

# ── Path encoding ────────────────────────────────────────────────────────────

def encode_path(path: str) -> str:
    """URL-encode each path segment, preserving slashes."""
    parts = [p for p in path.strip("/").split("/") if p]
    if not parts:
        return ""
    return "/" + "/".join(urllib.parse.quote(p, safe="") for p in parts)

def dav_href(path: str) -> str:
    """Convert user-facing /path to full DAV href (URL-encoded) for self-filtering."""
    parts = [p for p in path.strip("/").split("/") if p]
    if not parts:
        return DAV_PREFIX
    return DAV_PREFIX + "/" + "/".join(urllib.parse.quote(p, safe="") for p in parts)

def href_to_user_path(href: str) -> str:
    """Strip DAV prefix from an href to get the user-facing path."""
    decoded = urllib.parse.unquote(href).rstrip("/")
    if decoded.startswith(DAV_PREFIX):
        return decoded[len(DAV_PREFIX):] or "/"
    return decoded

def build_url(path: str) -> str:
    """Build full URL from user-facing path."""
    encoded = encode_path(path)
    return DAV_BASE + encoded if encoded else DAV_BASE + "/"

def _normalise(path: str) -> str:
    """Ensure path starts with /, strip trailing /."""
    path = path.rstrip("/")
    if not path.startswith("/"):
        path = "/" + path
    return path

def _clean_etag(etag: str) -> str:
    """Strip quotes and decode HTML entities from etag values."""
    return html.unescape(etag).strip('"')

# ── Curl wrapper (credentials via stdin, never in argv) ──────────────────────

_AUTH_CONFIG = f"user = {USER}:{TOKEN}\n"

def _is_transient(code: str) -> bool:
    """A request is worth retrying on a network error or a 5xx server error."""
    return code == "000" or code.startswith("5")

def _split_curl_body_code(stdout: str) -> tuple[str, str]:
    """Split curl body from HTTP code using a sentinel marker, not fragile last-line guessing."""
    marker = "\n" + HTTP_CODE_MARKER
    if marker not in stdout:
        return "", stdout.strip()
    body, code = stdout.rsplit(marker, 1)
    return body, code.strip()

def curl(*args, capture=True, max_time=120):
    """Run curl with auth via stdin. Returns CompletedProcess.

    `max_time` bounds curl's own transfer time AND the subprocess wall clock
    (with a 30s buffer), so large transfers are not killed prematurely.
    """
    cmd = ["curl", "-s", "--connect-timeout", "10", "--max-time", str(max_time), "-K", "-"] + list(args)
    return subprocess.run(
        cmd, input=_AUTH_CONFIG, capture_output=capture, text=True, timeout=max_time + 30
    )

def curl_with_code(*args, max_time=120, retries=None):
    """Run curl with -w '%{http_code}'. Returns (body, http_code, stderr).

    Retries transient failures (network errors, 5xx) up to `retries` times
    (defaults to the global RETRIES). All operations issued through this helper
    are idempotent, so retrying is safe.
    """
    if retries is None:
        retries = RETRIES
    attempt = 0
    while True:
        try:
            r = curl(*args, "-w", f"\n{HTTP_CODE_MARKER}%{{http_code}}", max_time=max_time)
            if r.returncode != 0:
                body, code, stderr = "", "000", r.stderr.strip()
            else:
                body, code = _split_curl_body_code(r.stdout)
                stderr = ""
        except subprocess.TimeoutExpired:
            body, code, stderr = "", "000", "curl timed out"

        if not _is_transient(code) or attempt >= retries:
            return body, code, stderr
        attempt += 1
        sys.stderr.write(
            f"  transient failure (HTTP {code or 'network'}), retry {attempt}/{retries}...\n"
        )
        time.sleep(2 * attempt)

# ── XML parsing ──────────────────────────────────────────────────────────────

# Precise collection detection using the actual XML tag structure,
# not substring "collection" which falsely matches filenames like "collection.txt"
_RE_COLLECTION = re.compile(
    r"<d:resourcetype>\s*<d:collection\s*/?\s*>\s*</d:resourcetype>", re.DOTALL
)
_RE_HREF = re.compile(r"<d:href>([^<]+)</d:href>")
_RE_SIZE = re.compile(r"<d:getcontentlength>(\d+)</d:getcontentlength>")
_RE_MODIFIED = re.compile(r"<d:getlastmodified>([^<]+)</d:getlastmodified>")
_RE_ETAG = re.compile(r"<d:getetag>([^<]+)</d:getetag>")
_RE_RESPONSE = re.compile(r"<d:response>(.*?)</d:response>", re.DOTALL)

def parse_entry(block: str, self_href: str = None) -> "dict | None":
    """Parse a single <d:response> block into an entry dict. Returns None if self."""
    href_m = _RE_HREF.search(block)
    if not href_m:
        return None
    raw_href = urllib.parse.unquote(href_m.group(1)).rstrip("/")

    # Path-based self-filter (not name-based)
    # Old code compared basenames only — broke when a child had the same name as parent
    if self_href is not None and raw_href == self_href.rstrip("/"):
        return None

    user_path = href_to_user_path(raw_href)
    name = raw_href.rsplit("/", 1)[-1] if "/" in raw_href else raw_href

    is_dir = bool(_RE_COLLECTION.search(block))

    entry = {
        "name": name,
        "type": "dir" if is_dir else "file",  # consistent: "dir" everywhere
        "path": user_path,
        "dav_href": raw_href,
    }

    size_m = _RE_SIZE.search(block)
    if size_m:
        entry["size"] = int(size_m.group(1))

    mod_m = _RE_MODIFIED.search(block)
    if mod_m:
        entry["modified"] = mod_m.group(1)

    etag_m = _RE_ETAG.search(block)
    if etag_m:
        entry["etag"] = _clean_etag(etag_m.group(1))

    return entry

def parse_propfind_xml(xml: str, self_href: str) -> list:
    """Parse PROPFIND/SEARCH response, filtering self entry by path."""
    entries = []
    for block in _RE_RESPONSE.findall(xml):
        entry = parse_entry(block, self_href)
        if entry is not None:
            entries.append(entry)
    return entries

# ── Output helpers ───────────────────────────────────────────────────────────

def out_json(ok: bool, http_code: str, data=None, error: str = None, exit_code: int = None) -> int:
    """Print agent-oriented JSON and return exit code."""
    if exit_code is None:
        exit_code = EXIT_OK if ok else (
            http_exit_code(http_code) if http_code != "000" else EXIT_NETWORK
        )
    payload = {"ok": ok, "http_code": http_code, "data": data, "error": error}
    print(json.dumps(payload, ensure_ascii=False))
    return exit_code

def err(msg: str, exit_code: int) -> int:
    """Print to stderr and return exit code."""
    sys.stderr.write(msg + "\n")
    return exit_code

def fail(msg: str, exit_code: int, json_mode: bool = False, http_code: str = "000", data=None) -> int:
    """Return either JSON failure or stderr failure using the same exit code."""
    return out_json(False, http_code, data=data, error=msg, exit_code=exit_code) if json_mode else err(f"ERROR: {msg}", exit_code)

def ok_json_or_print(json_mode: bool, http_code: str, data: dict, message: str) -> int:
    if json_mode:
        return out_json(True, http_code, data=data)
    print(message)
    return EXIT_OK

def _sort_key(e):
    return (0 if e["type"] == "dir" else 1, e["name"])

def print_entries(entries: list, json_mode: bool, http_code: str, requested_path: str) -> int:
    """Unified list printer. Returns exit code."""
    if json_mode:
        return out_json(True, http_code, data={"path": requested_path, "items": entries})
    if not entries:
        print("(empty)")
        return EXIT_OK
    for e in sorted(entries, key=_sort_key):
        icon = "📁" if e["type"] == "dir" else "📄"
        print(f"{icon} {e['name']}")
    return EXIT_OK

# ── Commands ─────────────────────────────────────────────────────────────────

def cmd_ls(path="/", json_mode=False, recursive=False):
    path = _normalise(path)
    self_href = dav_href(path)
    depth = "infinity" if recursive else "1"

    # URL for PROPFIND: always needs trailing / for directories
    url = build_url(path)
    if not url.endswith("/"):
        url += "/"

    body, code, stderr = curl_with_code("-X", "PROPFIND", "-H", f"Depth: {depth}", url)

    if stderr:
        msg = f"curl error: {stderr}"
        return out_json(False, "000", error=msg, exit_code=EXIT_NETWORK) if json_mode \
            else err(f"ERROR: {msg}", EXIT_NETWORK)

    if code == "404":
        msg = f"Directory not found: {path} (HTTP 404)"
        return out_json(False, code, error=msg, exit_code=EXIT_NOT_FOUND) if json_mode \
            else err(f"ERROR: {msg}", EXIT_NOT_FOUND)
    if code in ("401", "403"):
        msg = f"Authentication failed (HTTP {code}). Check NEXTCLOUD_USER and NEXTCLOUD_APP_PASSWORD."
        return out_json(False, code, error=msg, exit_code=EXIT_AUTH) if json_mode \
            else err(f"ERROR: {msg}", EXIT_AUTH)
    if code != "207":
        msg = f"PROPFIND failed (HTTP {code})"
        return out_json(False, code, error=msg, exit_code=http_exit_code(code)) if json_mode \
            else err(f"ERROR: {msg}", http_exit_code(code))

    entries = parse_propfind_xml(body, self_href)
    return print_entries(entries, json_mode, code, path)


def _human(n) -> str:
    """Format a byte count as a human-readable string."""
    if not isinstance(n, int) or n < 0:
        return str(n)
    units = ["B", "KB", "MB", "GB", "TB", "PB"]
    f = float(n)
    i = 0
    while f >= 1024 and i < len(units) - 1:
        f /= 1024
        i += 1
    return f"{n} B" if i == 0 else f"{f:.1f} {units[i]}"

def _sha1_file(path: str) -> str:
    """SHA1 hex digest of a file, read in 1 MiB blocks."""
    h = hashlib.sha1()
    with open(path, "rb") as f:
        for block in iter(lambda: f.read(1 << 20), b""):
            h.update(block)
    return h.hexdigest()

def _upload_timeout(nbytes: int) -> int:
    """Generous curl timeout for a transfer: assume >= 2 MB/s, floor 120s."""
    return max(120, int(nbytes / (2 * 1024 * 1024)) + 120)

def _curl_put(file_path, url, extra_headers, max_time, show_progress, retries=None):
    """PUT a single file with curl. Returns (http_code, stderr).

    When show_progress is set, curl's progress bar streams to the inherited
    stderr (TTY only); otherwise stderr is captured. Retries transient failures.
    """
    if retries is None:
        retries = RETRIES
    cmd = ["curl", "--progress-bar" if show_progress else "-s",
           "--connect-timeout", "10", "--max-time", str(max_time), "-K", "-"]
    for h in extra_headers:
        cmd += ["-H", h]
    cmd += ["-T", file_path, "-o", "/dev/null", "-w", f"\n{HTTP_CODE_MARKER}%{{http_code}}", url]

    attempt = 0
    while True:
        try:
            r = subprocess.run(
                cmd, input=_AUTH_CONFIG, text=True,
                stdout=subprocess.PIPE,
                stderr=(None if show_progress else subprocess.PIPE),
                timeout=max_time + 30,
            )
            _, code = _split_curl_body_code(r.stdout or "")
            stderr = "" if show_progress else (r.stderr or "").strip()
        except subprocess.TimeoutExpired:
            code, stderr = "000", "curl timed out"
        if not _is_transient(code) or attempt >= retries:
            return code, stderr
        attempt += 1
        sys.stderr.write(
            f"  transient PUT failure (HTTP {code or 'network'}), retry {attempt}/{retries}...\n"
        )
        time.sleep(2 * attempt)

def _upload_result(code, stderr, size, remote_path, json_mode=False, chunked=False, chunks=None):
    """Map an upload/assembly HTTP code to output + exit code."""
    if code in ("201", "204"):
        data = {"operation": "upload", "path": remote_path, "bytes": size, "chunked": chunked}
        if chunks is not None:
            data["chunks"] = chunks
        return ok_json_or_print(json_mode, code, data, f"OK ({code}) — {size:,} bytes → {remote_path}" + (f" (chunked, {chunks} chunks)" if chunked and chunks is not None else ""))
    if code == "413":
        return fail(
            "Upload exceeds server size limit (HTTP 413). Lower --chunk-size, or raise APACHE_BODY_LIMIT / PHP limits on the server.",
            EXIT_SIZE_LIMIT, json_mode, code
        )
    if code == "400":
        # With our controlled headers, a 400 on PUT/MOVE means the server's
        # OC-Checksum verification rejected the transfer.
        return fail(
            "Server checksum mismatch (HTTP 400). Source may have changed mid-upload — re-read the file and retry.",
            EXIT_CHECKSUM, json_mode, code
        )
    if code in ("401", "403"):
        return fail(f"Authentication failed (HTTP {code})", EXIT_AUTH, json_mode, code)
    if code == "404":
        return fail(
            f"Target directory not found: {remote_path} (HTTP 404). Create it with 'nc mkdir' first.",
            EXIT_NOT_FOUND, json_mode, code
        )
    hint = ""
    if _is_transient(code):
        hint = " HINT: large single upload? the default chunked path avoids 502s — drop --no-chunk or lower --chunk-size."
    detail = f" {stderr}" if stderr else ""
    return fail(
        f"Upload failed (HTTP {code}).{hint}{detail}",
        http_exit_code(code) if code != "000" else EXIT_NETWORK, json_mode, code
    )

# Headers shared by single and chunked uploads.
def _upload_meta_headers(mtime, checksum):
    return [
        f"X-OC-MTime: {mtime}",
        f"OC-Checksum: {checksum}",
        "X-NC-WebDAV-AutoMkcol: 1",
    ]

def _upload_single(local_path, remote_path, size, mtime, json_mode=False):
    url = build_url(remote_path)
    checksum = "SHA1:" + _sha1_file(local_path)
    headers = _upload_meta_headers(mtime, checksum)
    show_progress = size > 10 * 1024 * 1024 and sys.stderr.isatty()
    sys.stderr.write(f"Uploading {size:,} bytes ({_human(size)}) → {remote_path}...\n")
    code, stderr = _curl_put(local_path, url, headers, _upload_timeout(size), show_progress)
    return _upload_result(code, stderr, size, remote_path, json_mode=json_mode)

def _chunk_cleanup(upload_dir):
    """Best-effort delete of a chunked-upload session directory."""
    try:
        curl_with_code("-X", "DELETE", "-o", "/dev/null", upload_dir + "/", max_time=30, retries=0)
    except Exception:
        pass

def _upload_chunked(local_path, remote_path, size, chunk_size, mtime, json_mode=False):
    """Upload via Nextcloud's chunked upload API (MKCOL → PUT chunks → MOVE .file)."""
    upload_id = uuid.uuid4().hex
    upload_dir = f"{URL}/remote.php/dav/uploads/{USER}/{upload_id}"
    dest_url = build_url(remote_path)
    checksum = "SHA1:" + _sha1_file(local_path)
    n_chunks = (size + chunk_size - 1) // chunk_size
    tmp_dir = os.path.dirname(os.path.abspath(local_path))  # same FS as source → known free space

    sys.stderr.write(
        f"Uploading {size:,} bytes ({_human(size)}) → {remote_path} "
        f"(chunked: {n_chunks} × {_human(chunk_size)})...\n"
    )

    # 1) Open the upload session.
    _, code, stderr = curl_with_code(
        "-X", "MKCOL", "-o", "/dev/null",
        "-H", f"Destination: {dest_url}",
        "-H", f"OC-Total-Length: {size}",
        upload_dir + "/", max_time=60,
    )
    if code != "201":
        if code in ("401", "403"):
            return err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)
        return err(
            f"ERROR: Could not open upload session (HTTP {code}).{(' ' + stderr) if stderr else ''}",
            http_exit_code(code) if code != "000" else EXIT_NETWORK,
        )

    # 2) Upload each chunk.
    try:
        with open(local_path, "rb") as f:
            for i in range(n_chunks):
                data = f.read(chunk_size)
                chunk_url = f"{upload_dir}/{i + 1:05d}"
                with tempfile.NamedTemporaryFile(prefix="nc-chunk-", dir=tmp_dir, delete=False) as tmp:
                    tmp.write(data)
                    tmp_path = tmp.name
                try:
                    show_progress = len(data) > 10 * 1024 * 1024 and sys.stderr.isatty()
                    code, stderr = _curl_put(
                        tmp_path, chunk_url,
                        [f"Destination: {dest_url}", f"OC-Total-Length: {size}"],
                        _upload_timeout(len(data)), show_progress,
                    )
                finally:
                    os.remove(tmp_path)

                if code not in ("201", "204"):
                    _chunk_cleanup(upload_dir)
                    if code in ("401", "403"):
                        return err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)
                    if code == "413":
                        return err(
                            "ERROR: Chunk exceeds server limit (HTTP 413). Lower --chunk-size.",
                            EXIT_SIZE_LIMIT,
                        )
                    return err(
                        f"ERROR: Chunk {i + 1}/{n_chunks} failed (HTTP {code})."
                        f"{(' ' + stderr) if stderr else ''}",
                        http_exit_code(code) if code != "000" else EXIT_NETWORK,
                    )
                if not show_progress:
                    sys.stderr.write(f"  chunk {i + 1}/{n_chunks} ok ({_human(len(data))})\n")
    except OSError as e:
        _chunk_cleanup(upload_dir)
        return err(f"ERROR: Reading local file failed: {e}", EXIT_USAGE)

    # 3) Assemble: MOVE the virtual .file to the destination.
    _, code, stderr = curl_with_code(
        "-X", "MOVE",
        "-H", f"Destination: {dest_url}",
        "-H", "Overwrite: T",
        *[h for header in _upload_meta_headers(mtime, checksum) for h in ("-H", header)],
        "-o", "/dev/null",
        f"{upload_dir}/.file", max_time=_upload_timeout(size),
    )
    if code in ("201", "204"):
        return _upload_result(code, stderr, size, remote_path, json_mode=json_mode, chunked=True, chunks=n_chunks)
    _chunk_cleanup(upload_dir)
    return _upload_result(code, stderr, size, remote_path, json_mode=json_mode, chunked=True, chunks=n_chunks)

def cmd_upload(local_path, remote_path, no_chunk=False, no_clobber=False, chunk_size_mb=None, json_mode=False):
    if not os.path.exists(local_path):
        sys.stderr.write(f"ERROR: File not found: {local_path}\n")
        return EXIT_USAGE
    if os.path.isdir(local_path):
        sys.stderr.write(f"ERROR: Is a directory (upload single files): {local_path}\n")
        return EXIT_USAGE

    if chunk_size_mb is not None and chunk_size_mb <= 0:
        sys.stderr.write("ERROR: --chunk-size must be a positive number of MB\n")
        return EXIT_USAGE

    size = os.path.getsize(local_path)
    remote_path = _normalise(remote_path)
    mtime = int(os.path.getmtime(local_path))
    chunk_size = (chunk_size_mb or DEFAULT_CHUNK_MB) * 1024 * 1024

    if no_clobber:
        _, head_code, _ = curl_with_code("-I", build_url(remote_path), max_time=30)
        if head_code == "200":
            return err(
                f"ERROR: Target exists and --no-clobber is set: {remote_path} (HTTP 409)",
                EXIT_CONFLICT,
            )

    if not no_chunk and size > chunk_size:
        return _upload_chunked(local_path, remote_path, size, chunk_size, mtime, json_mode=json_mode)
    return _upload_single(local_path, remote_path, size, mtime, json_mode=json_mode)


def _remove_if_exists(path: str):
    try:
        if os.path.exists(path):
            os.remove(path)
    except OSError:
        pass


def cmd_download(remote_path, local_path, json_mode=False):
    remote_path = _normalise(remote_path)
    url = build_url(remote_path)

    # HEAD first to check existence and get content-length.
    h_body, h_code, h_err = curl_with_code("-I", url, max_time=30)
    if h_err:
        return fail(f"curl: {h_err}", EXIT_NETWORK, json_mode, "000")
    if h_code != "200":
        if h_code == "404":
            return fail(f"File not found: {remote_path} (HTTP 404)", EXIT_NOT_FOUND, json_mode, h_code)
        if h_code in ("401", "403"):
            return fail(f"Authentication failed (HTTP {h_code})", EXIT_AUTH, json_mode, h_code)
        return fail(f"Cannot download {remote_path} (HTTP {h_code})", http_exit_code(h_code), json_mode, h_code)

    cl_m = re.search(r"content-length:\s*(\d+)", h_body, re.IGNORECASE)
    expected_size = int(cl_m.group(1)) if cl_m else None

    sys.stderr.write(f"Downloading {remote_path} → {local_path}...\n")

    local_parent = os.path.dirname(os.path.abspath(local_path)) or "."
    os.makedirs(local_parent, exist_ok=True)
    tmp_path = local_path + ".part"
    _remove_if_exists(tmp_path)

    dl_timeout = _upload_timeout(expected_size) if expected_size else 600
    r = curl("-f", "-o", tmp_path, "-w", f"\n{HTTP_CODE_MARKER}%{{http_code}}", url, max_time=dl_timeout)
    _, http_code = _split_curl_body_code(r.stdout or "")

    if r.returncode != 0:
        _remove_if_exists(tmp_path)
        _remove_if_exists(local_path)
        detail = (r.stderr or "").strip()
        return fail(f"Download failed (curl exit {r.returncode}, HTTP {http_code or '000'}): {detail}", EXIT_NETWORK, json_mode, http_code or "000")

    if http_code and http_code != "200" and http_code != "000":
        _remove_if_exists(tmp_path)
        _remove_if_exists(local_path)
        return fail(f"Download failed (HTTP {http_code})", http_exit_code(http_code), json_mode, http_code)

    if not os.path.exists(tmp_path):
        _remove_if_exists(local_path)
        return fail("File not created after download", EXIT_NETWORK, json_mode, http_code or "000")

    actual_size = os.path.getsize(tmp_path)
    if expected_size is not None and actual_size != expected_size:
        _remove_if_exists(tmp_path)
        return fail(
            f"Size mismatch — expected {expected_size:,} bytes, got {actual_size:,} bytes. Transfer incomplete.",
            EXIT_NETWORK, json_mode, http_code or "200"
        )

    os.replace(tmp_path, local_path)
    return ok_json_or_print(
        json_mode, http_code or "200",
        {"operation": "download", "remote_path": remote_path, "local_path": local_path, "bytes": actual_size},
        f"OK — {actual_size:,} bytes → {local_path}",
    )

def cmd_mkdir(path, json_mode=False):
    path = _normalise(path)
    url = build_url(path)
    if not url.endswith("/"):
        url += "/"

    body, code, stderr = curl_with_code("-X", "MKCOL", "-o", "/dev/null", url)

    if stderr:
        return err(f"ERROR: curl: {stderr}", EXIT_NETWORK)
    if code == "201":
        return ok_json_or_print(json_mode, code, {"operation": "mkdir", "path": path}, f"OK — created {path}/")
    if code == "405":
        # Already exists — idempotent, not an error
        sys.stderr.write(f"NOTE: {path}/ already exists (HTTP 405)\n")
        return ok_json_or_print(json_mode, code, {"operation": "mkdir", "path": path, "already_exists": True}, f"OK (already exists) — {path}/")
    if code == "404":
        return err(f"ERROR: Parent directory not found (HTTP 404). Create parents first.", EXIT_NOT_FOUND)
    if code in ("401", "403"):
        return err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)
    return err(f"ERROR: mkdir failed (HTTP {code})", http_exit_code(code))


def cmd_mv(src, dst, overwrite=False, json_mode=False):
    src = _normalise(src)
    dst = _normalise(dst)
    src_url = build_url(src)
    dst_url = build_url(dst)

    headers = [
        "-X", "MOVE",
        "-H", f"Destination: {dst_url}",
        "-H", f"Overwrite: {'T' if overwrite else 'F'}",
    ]
    body, code, stderr = curl_with_code(*headers, "-o", "/dev/null", src_url)

    if stderr:
        return err(f"ERROR: curl: {stderr}", EXIT_NETWORK)
    if code in ("201", "204"):
        return ok_json_or_print(json_mode, code, {"operation": "mv", "src": src, "dst": dst, "overwrite": overwrite}, f"OK — {src} → {dst}")
    if code in ("409", "412"):
        return err(
            f"ERROR: Destination already exists: {dst} (HTTP {code}). "
            "Use --overwrite to replace.",
            EXIT_CONFLICT,
        )
    if code == "404":
        return err(f"ERROR: Source not found: {src} (HTTP 404)", EXIT_NOT_FOUND)
    if code in ("401", "403"):
        return err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)
    return err(f"ERROR: mv failed (HTTP {code})", http_exit_code(code))


def cmd_cp(src, dst, overwrite=False, json_mode=False):
    src = _normalise(src)
    dst = _normalise(dst)
    src_url = build_url(src)
    dst_url = build_url(dst)

    headers = [
        "-X", "COPY",
        "-H", f"Destination: {dst_url}",
        "-H", f"Overwrite: {'T' if overwrite else 'F'}",
    ]
    body, code, stderr = curl_with_code(*headers, "-o", "/dev/null", src_url)

    if stderr:
        return err(f"ERROR: curl: {stderr}", EXIT_NETWORK)
    if code in ("201", "204"):
        return ok_json_or_print(json_mode, code, {"operation": "cp", "src": src, "dst": dst, "overwrite": overwrite}, f"OK — {src} → {dst}")
    if code in ("409", "412"):
        return err(
            f"ERROR: Destination already exists: {dst} (HTTP {code}). "
            "Use --overwrite to replace.",
            EXIT_CONFLICT,
        )
    if code == "404":
        return err(f"ERROR: Source not found: {src} (HTTP 404)", EXIT_NOT_FOUND)
    if code in ("401", "403"):
        return err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)
    return err(f"ERROR: cp failed (HTTP {code})", http_exit_code(code))


DEFAULT_PROTECTED_DELETE_PATHS = {"/HERMES-DROP", "/Obsidian", "/_INTEGRARTE.ARQ"}


def _protected_delete_paths() -> set[str]:
    """Protected remote paths. Override with comma-separated NC_PROTECTED_DELETE_PATHS."""
    raw = os.environ.get("NC_PROTECTED_DELETE_PATHS")
    if raw is None:
        return DEFAULT_PROTECTED_DELETE_PATHS
    paths = set()
    for item in raw.split(","):
        item = item.strip()
        if not item:
            continue
        paths.add(_normalise(item))
    return paths


def _remote_type(path: str) -> tuple[str | None, str, str]:
    """Return (type, http_code, stderr), where type is 'file', 'dir', or None."""
    url = build_url(path)
    body, code, stderr = curl_with_code("-X", "PROPFIND", "-H", "Depth: 0", url, max_time=30)
    if code != "207":
        return None, code, stderr
    return ("dir" if _RE_COLLECTION.search(body) else "file"), code, stderr


def cmd_rm(path, recursive=False, force=False, json_mode=False):
    path = _normalise(path)
    if path == "/":
        return fail("Refusing to delete root /. Use a narrower path.", EXIT_USAGE, json_mode, "000")

    rtype, probe_code, probe_stderr = _remote_type(path)
    if probe_stderr:
        return fail(f"curl: {probe_stderr}", EXIT_NETWORK, json_mode, "000")
    if probe_code == "404":
        return fail(f"Not found: {path} (HTTP 404)", EXIT_NOT_FOUND, json_mode, probe_code)
    if probe_code in ("401", "403"):
        return fail(f"Authentication failed (HTTP {probe_code})", EXIT_AUTH, json_mode, probe_code)
    if probe_code != "207":
        return fail(f"rm preflight failed (HTTP {probe_code})", http_exit_code(probe_code), json_mode, probe_code)

    if rtype == "dir" and not recursive:
        return fail(f"Refusing to delete directory {path}: directory deletion requires --recursive.", EXIT_USAGE, json_mode, probe_code)
    if path in _protected_delete_paths() and not force:
        return fail(f"Refusing to delete protected path {path}: use --force if you really mean it.", EXIT_USAGE, json_mode, probe_code)

    url = build_url(path)
    body, code, stderr = curl_with_code("-X", "DELETE", "-o", "/dev/null", url)

    if stderr:
        return fail(f"curl: {stderr}", EXIT_NETWORK, json_mode, "000")
    if code in ("204", "200"):
        return ok_json_or_print(json_mode, code, {"operation": "rm", "path": path, "type": rtype}, f"OK — deleted {path}")
    if code == "404":
        return fail(f"Not found: {path} (HTTP 404)", EXIT_NOT_FOUND, json_mode, code)
    if code in ("401", "403"):
        return fail(f"Authentication failed (HTTP {code})", EXIT_AUTH, json_mode, code)
    return fail(f"rm failed (HTTP {code})", http_exit_code(code), json_mode, code)

def cmd_search(query, search_path="/", json_mode=False):
    search_path = _normalise(search_path)
    url = build_url(search_path)
    if not url.endswith("/"):
        url += "/"

    body_xml = (
        '<?xml version="1.0"?>\n'
        '<d:searchrequest xmlns:d="DAV:">'
        '<d:basicsearch>'
        '<d:select><d:prop>'
        '<d:displayname/><d:getcontentlength/><d:resourcetype/>'
        '<d:getlastmodified/><d:getetag/>'
        '</d:prop></d:select>'
        '<d:from><d:scope>'
        f'<d:href>{url}</d:href>'
        '<d:depth>infinity</d:depth>'
        '</d:scope></d:from>'
        '<d:where><d:like>'
        '<d:prop><d:displayname/></d:prop>'
        f'<d:literal>%{html.escape(query, quote=True)}%</d:literal>'
        '</d:like></d:where>'
        '</d:basicsearch></d:searchrequest>'
    )

    r = curl(
        "-X", "SEARCH", "-H", "Content-Type: application/xml",
        "-d", body_xml, "-w", f"\n{HTTP_CODE_MARKER}%{{http_code}}", url,
    )

    if r.returncode != 0:
        msg = f"curl error: {r.stderr.strip()}"
        return out_json(False, "000", error=msg, exit_code=EXIT_NETWORK) if json_mode \
            else err(f"ERROR: {msg}", EXIT_NETWORK)

    resp_body, code = _split_curl_body_code(r.stdout)

    # HTTP 501 = SEARCH not implemented
    if code == "501":
        msg = (
            "SEARCH method not supported (HTTP 501). "
            "Fallback: nc ls <path> --json --recursive | jq '[.data.items[] | select(.name | test(\"query\"))]'"
        )
        return out_json(False, code, error=msg, exit_code=EXIT_SERVER) if json_mode \
            else err(f"ERROR: {msg}", EXIT_SERVER)

    # HTTP 400 = query rejected (some servers return this instead of 501)
    if code == "400":
        msg = "Search query rejected by server (HTTP 400). Server may not support SEARCH. Use ls --recursive fallback."
        return out_json(False, code, error=msg, exit_code=EXIT_SERVER) if json_mode \
            else err(f"ERROR: {msg}", EXIT_SERVER)

    if code in ("401", "403"):
        return out_json(False, code, error=f"Authentication failed (HTTP {code})", exit_code=EXIT_AUTH) if json_mode \
            else err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)

    if code not in ("207", "200"):
        msg = f"Search failed (HTTP {code})"
        return out_json(False, code, error=msg, exit_code=http_exit_code(code)) if json_mode \
            else err(f"ERROR: {msg}", http_exit_code(code))

    # Also detect NotImplemented in response body (some servers return 207 but with error embedded)
    if "NotImplemented" in resp_body or "no plugin" in resp_body.lower():
        msg = "Search not supported. Use 'nc ls --json --recursive' and filter locally."
        return out_json(False, code, error=msg, exit_code=EXIT_SERVER) if json_mode \
            else err(f"ERROR: {msg}", EXIT_SERVER)

    # Parse results — no self-filtering for search (we want all matches)
    entries = parse_propfind_xml(resp_body, self_href=None)
    return print_entries(entries, json_mode, code, search_path)


def cmd_info(path, json_mode=False):
    path = _normalise(path)
    url = build_url(path)

    # Request specific properties including fileid, permissions, creation time, etc.
    propfind_body = (
        '<?xml version="1.0"?>'
        '<d:propfind xmlns:d="DAV:" xmlns:oc="http://owncloud.org/ns" xmlns:nc="http://nextcloud.org/ns">'
        '<d:prop>'
        '<d:getcontentlength/><d:getlastmodified/><d:getetag/>'
        '<d:resourcetype/><d:getcontenttype/>'
        '<d:creationdate/>'
        '<d:quota-available-bytes/><d:quota-used-bytes/>'
        '<oc:fileid/><oc:permissions/>'
        '<nc:creation_time/><nc:mount-type/><nc:is-encrypted/>'
        '</d:prop></d:propfind>'
    )

    body, code, stderr = curl_with_code(
        "-X", "PROPFIND", "-H", "Depth: 0",
        "-H", "Content-Type: application/xml",
        "-d", propfind_body,
        url,
    )

    if stderr:
        msg = f"curl: {stderr}"
        return out_json(False, "000", error=msg, exit_code=EXIT_NETWORK) if json_mode \
            else err(f"ERROR: {msg}", EXIT_NETWORK)

    # Check HTTP code BEFORE parsing XML (fixes phantom-file bug on 404)
    if code == "404":
        msg = f"Not found: {path} (HTTP 404)"
        return out_json(False, code, error=msg, exit_code=EXIT_NOT_FOUND) if json_mode \
            else err(f"ERROR: {msg}", EXIT_NOT_FOUND)
    if code in ("401", "403"):
        return out_json(False, code, error=f"Authentication failed (HTTP {code})", exit_code=EXIT_AUTH) if json_mode \
            else err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)
    if code != "207":
        msg = f"PROPFIND failed (HTTP {code})"
        return out_json(False, code, error=msg, exit_code=http_exit_code(code)) if json_mode \
            else err(f"ERROR: {msg}", http_exit_code(code))

    # Precise collection detection (regex, not "collection" substring)
    is_dir = bool(_RE_COLLECTION.search(body))

    size_m = _RE_SIZE.search(body)
    mod_m = _RE_MODIFIED.search(body)
    etag_m = _RE_ETAG.search(body)
    fileid_m = re.search(r"<oc:fileid>(\d+)</oc:fileid>", body)
    ctype_m = re.search(r"<d:getcontenttype>([^<]+)</d:getcontenttype>", body)
    cdate_m = re.search(r"<d:creationdate>([^<]+)</d:creationdate>", body)
    perms_m = re.search(r"<oc:permissions>([^<]*)</oc:permissions>", body)
    nctime_m = re.search(r"<nc:creation_time>(\d+)</nc:creation_time>", body)
    mount_m = re.search(r"<nc:mount-type>([^<]*)</nc:mount-type>", body)
    enc_m = re.search(r"<nc:is-encrypted>(\d+)</nc:is-encrypted>", body)
    quota_avail_m = re.search(r"<d:quota-available-bytes>([^<]+)</d:quota-available-bytes>", body)
    quota_used_m = re.search(r"<d:quota-used-bytes>([^<]+)</d:quota-used-bytes>", body)

    info = {"path": path, "type": "dir" if is_dir else "file"}  # consistent "dir"/"file"
    if size_m:
        info["size"] = int(size_m.group(1))
    if mod_m:
        info["modified"] = mod_m.group(1)
    if etag_m:
        info["etag"] = _clean_etag(etag_m.group(1))
    if fileid_m:
        info["fileid"] = int(fileid_m.group(1))
    if ctype_m and not is_dir:
        info["content_type"] = ctype_m.group(1).strip()
    if cdate_m:
        cdate_val = cdate_m.group(1)
        # Suppress epoch-zero "created" dates — Nextcloud returns 1970-01-01 when unset
        if cdate_val and "1970-01-01" not in cdate_val:
            info["created"] = cdate_val
    if nctime_m:
        ts = int(nctime_m.group(1))
        if ts > 0:  # 0 means unset
            info["created_unix"] = ts
            # Add ISO format for easy parsing
            from datetime import datetime, timezone
            info["created_iso"] = datetime.fromtimestamp(ts, tz=timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    if perms_m:
        info["permissions"] = perms_m.group(1)
    if mount_m:
        mt = mount_m.group(1).strip()
        # Empty string means "local"
        info["mount_type"] = mt if mt else "local"
    if enc_m:
        info["encrypted"] = bool(int(enc_m.group(1)))
    if quota_avail_m:
        val = quota_avail_m.group(1)
        # -1=uncomputed, -2=unknown, -3=unlimited
        info["quota_available"] = int(val) if val.lstrip('-').isdigit() else val
    if quota_used_m:
        val = quota_used_m.group(1)
        info["quota_used"] = int(val) if val.lstrip('-').isdigit() else val

    if json_mode:
        return out_json(True, code, data=info)

    print(f"Path:     {info['path']}")
    print(f"Type:     {info['type']}")
    if "size" in info:
        print(f"Size:     {info['size']:,} bytes")
    if "modified" in info:
        print(f"Modified: {info['modified']}")
    if "created" in info:
        print(f"Created:  {info['created']}")
    if "created_iso" in info:
        print(f"Created (ISO): {info['created_iso']}")
    if "etag" in info:
        print(f"ETag:     {info['etag']}")
    if "fileid" in info:
        print(f"FileID:   {info['fileid']}")
    if "content_type" in info:
        print(f"MIME:     {info['content_type']}")
    if "permissions" in info:
        print(f"Perms:    {info['permissions']}")
    if "mount_type" in info:
        print(f"Mount:    {info['mount_type']}")
    if "encrypted" in info:
        print(f"Encrypted: {info['encrypted']}")
    if "quota_available" in info:
        qa = info['quota_available']
        print(f"Quota available: {qa:,} bytes" if isinstance(qa, int) and qa >= 0 else f"Quota available: {qa}")
    if "quota_used" in info:
        qu = info['quota_used']
        print(f"Quota used: {qu:,} bytes" if isinstance(qu, int) and qu >= 0 else f"Quota used: {qu}")
    return EXIT_OK


def cmd_share(path, password=None, json_mode=False):
    path = _normalise(path)
    ocs_url = f"{URL}/ocs/v2.php/apps/files_sharing/api/v1/shares"

    data = f"path={urllib.parse.quote(path)}&shareType=3&permissions=1"
    if password:
        data += f"&password={urllib.parse.quote(password)}"

    body, code, stderr = curl_with_code(
        "-X", "POST",
        "-H", "OCS-APIREQUEST: true",
        "-H", "Content-Type: application/x-www-form-urlencoded",
        "-d", data,
        ocs_url,
    )

    if stderr:
        return err(f"ERROR: curl: {stderr}", EXIT_NETWORK)

    url_m = re.search(r"<url>([^<]+)</url>", body)
    if url_m and code in ("200", "201"):
        share_url = url_m.group(1)
        return ok_json_or_print(json_mode, code, {"operation": "share", "path": path, "url": share_url, "password_protected": bool(password)}, share_url)

    if code in ("401", "403"):
        return err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)
    if code == "404":
        return err(f"ERROR: Path not found: {path} (HTTP 404)", EXIT_NOT_FOUND)
    return err(f"ERROR: Share failed (HTTP {code}). Response: {body[:300]}", http_exit_code(code))


def cmd_quota(path="/", json_mode=False):
    path = _normalise(path)
    url = build_url(path)
    if not url.endswith("/"):
        url += "/"

    propfind_body = (
        '<?xml version="1.0"?>'
        '<d:propfind xmlns:d="DAV:">'
        '<d:prop><d:quota-available-bytes/><d:quota-used-bytes/></d:prop>'
        '</d:propfind>'
    )
    body, code, stderr = curl_with_code(
        "-X", "PROPFIND", "-H", "Depth: 0",
        "-H", "Content-Type: application/xml",
        "-d", propfind_body, url,
    )

    if code == "000":
        msg = f"curl error: {stderr}"
        return out_json(False, "000", error=msg, exit_code=EXIT_NETWORK) if json_mode \
            else err(f"ERROR: {msg}", EXIT_NETWORK)
    if code in ("401", "403"):
        return out_json(False, code, error=f"Authentication failed (HTTP {code})", exit_code=EXIT_AUTH) if json_mode \
            else err(f"ERROR: Authentication failed (HTTP {code})", EXIT_AUTH)
    if code == "404":
        msg = f"Not found: {path} (HTTP 404)"
        return out_json(False, code, error=msg, exit_code=EXIT_NOT_FOUND) if json_mode \
            else err(f"ERROR: {msg}", EXIT_NOT_FOUND)
    if code != "207":
        msg = f"PROPFIND failed (HTTP {code})"
        return out_json(False, code, error=msg, exit_code=http_exit_code(code)) if json_mode \
            else err(f"ERROR: {msg}", http_exit_code(code))

    def _qval(raw):
        # Sentinels: -1 uncomputed, -2 unknown, -3 unlimited
        return int(raw) if raw.lstrip("-").isdigit() else raw

    avail_m = re.search(r"<d:quota-available-bytes>([^<]+)</d:quota-available-bytes>", body)
    used_m = re.search(r"<d:quota-used-bytes>([^<]+)</d:quota-used-bytes>", body)
    used = _qval(used_m.group(1)) if used_m else None
    avail = _qval(avail_m.group(1)) if avail_m else None

    data = {"path": path, "used": used, "available": avail}
    if isinstance(used, int) and isinstance(avail, int) and avail >= 0:
        total = used + avail
        data["total"] = total
        data["used_percent"] = round(used / total * 100, 1) if total else 0.0

    if json_mode:
        return out_json(True, code, data=data)

    print(f"Quota for {path}:")
    print(f"  Used:      {_human(used)}")
    sentinel = {-1: "uncomputed", -2: "unknown", -3: "unlimited"}
    if isinstance(avail, int) and avail < 0:
        print(f"  Available: {sentinel.get(avail, avail)}")
    else:
        print(f"  Available: {_human(avail)}")
    if "total" in data:
        print(f"  Total:     {_human(data['total'])}")
        print(f"  Use:       {data['used_percent']}%")
    return EXIT_OK


def cmd_help():
    print(__doc__)
    return EXIT_OK


# ── Argument parser ──────────────────────────────────────────────────────────

# Flags that are consumed globally (not passed to commands as positional args).
# A bare '--' stops flag parsing — everything after is positional.
KNOWN_GLOBAL_FLAGS = frozenset({"--json", "--recursive", "--no-retry", "--password-stdin"})
COMMAND_FLAGS = frozenset({"--overwrite", "--no-chunk", "--no-clobber", "--force"})  # boolean, command-specific
VALUE_FLAGS = frozenset({"--chunk-size", "--pw", "--password-env"})  # consume the following token as a value

def parse_args(argv):
    """
    Safe arg parser. Returns (cmd, positional_args, global_flags, command_flags, opts).

    Rules:
    - Global flags (--json, --recursive, --no-retry) → global_flags set
    - Boolean command flags (--overwrite, --no-chunk, --no-clobber) → command_flags set
    - Value flags (--chunk-size N) → opts dict {flag: value}
    - Everything else is positional
    - '--' stops ALL flag parsing (remaining tokens are positional)
    - Unknown flags (e.g. --foo) are treated as positional (forward-compatible)
    """
    if not argv:
        return None, [], set(), set(), {}

    cmd = argv[0]
    rest = argv[1:]
    positional = []
    global_flags = set()
    command_flags = set()
    opts = {}
    stop_flags = False

    idx = 0
    while idx < len(rest):
        tok = rest[idx]
        if tok == "--":
            stop_flags = True
            idx += 1
            continue
        if not stop_flags:
            if tok in KNOWN_GLOBAL_FLAGS:
                global_flags.add(tok)
                idx += 1
                continue
            if tok in COMMAND_FLAGS:
                command_flags.add(tok)
                idx += 1
                continue
            if tok in VALUE_FLAGS:
                opts[tok] = rest[idx + 1] if idx + 1 < len(rest) else None
                idx += 2
                continue
        positional.append(tok)
        idx += 1

    return cmd, positional, global_flags, command_flags, opts


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    global RETRIES

    if len(sys.argv) < 2:
        print(__doc__)
        return EXIT_OK

    cmd, args, gflags, cflags, opts = parse_args(sys.argv[1:])
    json_mode = "--json" in gflags
    recursive = "--recursive" in gflags
    overwrite = "--overwrite" in cflags
    if "--no-retry" in gflags:
        RETRIES = 0

    if cmd in ("help", "--help", "-h"):
        return cmd_help()
    if cmd in ("version", "--version"):
        print(f"nc {VERSION}")
        return EXIT_OK

    if cmd == "ls":
        path = args[0] if args else "/"
        return cmd_ls(path, json_mode=json_mode, recursive=recursive)

    elif cmd == "upload":
        if len(args) < 2:
            sys.stderr.write("Usage: nc upload <local> <remote> [--no-chunk] [--chunk-size MB] [--no-clobber]\n")
            return EXIT_USAGE
        chunk_size_mb = None
        if "--chunk-size" in opts:
            raw = opts["--chunk-size"]
            if raw is None or not raw.lstrip("-").isdigit():
                sys.stderr.write("ERROR: --chunk-size requires an integer number of MB\n")
                return EXIT_USAGE
            chunk_size_mb = int(raw)
        return cmd_upload(
            args[0], args[1],
            no_chunk="--no-chunk" in cflags,
            no_clobber="--no-clobber" in cflags,
            chunk_size_mb=chunk_size_mb,
            json_mode=json_mode,
        )

    elif cmd == "download":
        if len(args) < 2:
            sys.stderr.write("Usage: nc download <remote> <local>\n")
            return EXIT_USAGE
        return cmd_download(args[0], args[1], json_mode=json_mode)

    elif cmd == "mkdir":
        if len(args) < 1:
            sys.stderr.write("Usage: nc mkdir <path>\n")
            return EXIT_USAGE
        return cmd_mkdir(args[0], json_mode=json_mode)

    elif cmd == "mv":
        if len(args) < 2:
            sys.stderr.write("Usage: nc mv <src> <dst> [--overwrite]\n")
            return EXIT_USAGE
        return cmd_mv(args[0], args[1], overwrite=overwrite, json_mode=json_mode)

    elif cmd == "cp":
        if len(args) < 2:
            sys.stderr.write("Usage: nc cp <src> <dst> [--overwrite]\n")
            return EXIT_USAGE
        return cmd_cp(args[0], args[1], overwrite=overwrite, json_mode=json_mode)

    elif cmd == "rm":
        if len(args) < 1:
            sys.stderr.write("Usage: nc rm <path>\n")
            return EXIT_USAGE
        return cmd_rm(args[0], recursive=recursive, force="--force" in cflags, json_mode=json_mode)

    elif cmd == "search":
        if len(args) < 1:
            sys.stderr.write("Usage: nc search <query> [path]\n")
            return EXIT_USAGE
        return cmd_search(args[0], args[1] if len(args) > 1 else "/", json_mode=json_mode)

    elif cmd == "info":
        if len(args) < 1:
            sys.stderr.write("Usage: nc info <path>\n")
            return EXIT_USAGE
        return cmd_info(args[0], json_mode=json_mode)

    elif cmd == "quota":
        return cmd_quota(args[0] if args else "/", json_mode=json_mode)

    elif cmd == "share":
        if len(args) < 1:
            sys.stderr.write("Usage: nc share <path> [--pw password]\n")
            return EXIT_USAGE
        pw = None
        if "--pw" in opts:
            pw = opts["--pw"]
            if pw is None:
                sys.stderr.write("ERROR: --pw requires a password\n")
                return EXIT_USAGE
        if "--password-env" in opts:
            env_name = opts["--password-env"]
            if not env_name:
                sys.stderr.write("ERROR: --password-env requires an environment variable name\n")
                return EXIT_USAGE
            pw = os.environ.get(env_name)
            if pw is None:
                sys.stderr.write(f"ERROR: environment variable not set: {env_name}\n")
                return EXIT_USAGE
        if "--password-stdin" in gflags:
            pw = sys.stdin.read().rstrip("\n")
        return cmd_share(args[0] if args else "/", pw, json_mode=json_mode)

    else:
        sys.stderr.write(f"Unknown command: {cmd}\n")
        sys.stderr.write("Commands: ls, upload, download, mkdir, mv, cp, rm, search, info, quota, share, help\n")
        sys.stderr.write("Run 'nc help' for the full guide.\n")
        return EXIT_USAGE


if __name__ == "__main__":
    sys.exit(main())
